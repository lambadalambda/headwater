# Listener defaults to IPv4 loopback. Non-loopback binds also require
# DELTANET_ALLOW_NON_LOOPBACK=1; read the security notes in ../README.md first.
PORT=4030
DELTANET_HOSTNAME=127.0.0.1
# DELTANET_ALLOW_NON_LOOPBACK=1

# This origin is used in API URLs and is always trusted for CORS/OAuth redirects.
DELTANET_BASE_URL=http://localhost:4030

# Comma-separated additional browser origins. Add Vite explicitly when running
# the frontend dev server separately from the daemon-served production SPA.
# DELTANET_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Comma-separated HTTPS relay origins that callers may select during signup.
# The public default is always allowed. This operator-only setting is also the
# explicit opt-in for private/loopback relays; paths, credentials, and HTTP are
# rejected. Certificates must remain valid outside the isolated test harness.
# DELTANET_SIGNUP_RELAYS=https://relay.example,https://127.0.0.1:8443

DELTANET_ACCOUNT=main
DELTANET_DATA=data/main
DELTANET_ACCOUNTS=accounts.local.json
# Kept outside DELTANET_DATA so first-time core setup/restore still sees the
# account directory shape it expects. It stores mode-0600 hashed auth state and
# signing material; deleting it invalidates clients/sessions. The default is
# ${DELTANET_DATA}.auth.json.
# DELTANET_AUTH=data/main.auth.json
DELTANET_STATIC=../frontend/build
