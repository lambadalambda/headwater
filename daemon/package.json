{
  "name": "deltanet",
  "version": "0.0.1",
  "description": "A single-user Pleroma-style backend that federates over chatmail (Delta Chat transport) instead of ActivityPub",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:watch": "vitest --exclude 'tests/integration/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "check": "tsc --noEmit",
    "setup-account": "tsx scripts/setup-account.ts"
  },
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "@deltachat/jsonrpc-client": "^2.53.0",
    "@deltachat/stdio-rpc-server": "^2.53.0",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.27",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
