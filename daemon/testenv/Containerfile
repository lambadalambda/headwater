# Ephemeral chatmail relay for DeltaNet integration tests.
#
# Builds a real github.com/chatmail/relay via its own `cmdeploy` tool on a
# Debian 12 + systemd base. Structure mirrors the upstream chatmail/docker
# image (studied while writing this):
#
#   - build time: clone the relay at a pinned ref, create the cmdeploy venv,
#     and run ONLY the `install` stage (apt packages, chatmaild venv). This
#     stage is explicitly container/non-systemd aware (basedeploy.has_systemd
#     / is_in_container), so it runs fine during an image build with no PID-1
#     systemd.
#   - first boot: systemd comes up as PID 1; a oneshot `chatmail-init.service`
#     runs `cmdeploy init` + `cmdeploy run --ssh-host @local --skip-dns-check`,
#     which performs the `configure,activate` stages: generates a self-signed
#     cert, writes service configs, and starts postfix/dovecot/nginx/etc.
#
# No external DNS is needed: the mail_domain starts with `_` so config.py
# selects tls_cert_mode=self, and the daemon connects by explicit IMAP/SMTP
# host:port (see daemon/src/transport/deltachat.ts explicit-server path).

ARG DEBIAN_VERSION=12
# Pinned relay ref (chatmail/relay). Bump deliberately; the whole point of the
# local relay is reproducibility.
ARG RELAY_REF=3a553f2286f50ce86ee53b3989605914aa9b3dba
ARG RELAY_URL=https://github.com/chatmail/relay.git

# ── systemd base (vendored from jrei/systemd-debian, as upstream docker does) ──
FROM debian:${DEBIAN_VERSION} AS systemd-base

ENV LC_ALL=C
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y systemd systemd-sysv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN cd /lib/systemd/system/sysinit.target.wants/ \
    && rm $(ls | grep -v systemd-tmpfiles-setup)

RUN rm -f /lib/systemd/system/multi-user.target.wants/* \
    /etc/systemd/system/*.wants/* \
    /lib/systemd/system/local-fs.target.wants/* \
    /lib/systemd/system/sockets.target.wants/*udev* \
    /lib/systemd/system/sockets.target.wants/*initctl* \
    /lib/systemd/system/basic.target.wants/* \
    /lib/systemd/system/anaconda.target.wants/* \
    /lib/systemd/system/plymouth* \
    /lib/systemd/system/systemd-update-utmp*

VOLUME [ "/sys/fs/cgroup" ]

# ── chatmail relay image ──
FROM systemd-base AS relay

ARG RELAY_REF
ARG RELAY_URL

ENV LANG=en_US.UTF-8
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y \
        ca-certificates \
        gcc \
        git \
        python3 \
        python3-dev \
        python3-venv \
        tzdata \
        locales && \
    sed -i -e "s/# en_US.UTF-8.*/en_US.UTF-8 UTF-8/" /etc/locale.gen && \
    dpkg-reconfigure --frontend=noninteractive locales && \
    update-locale LANG=en_US.UTF-8 && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Clone the relay at the pinned ref.
RUN git clone "$RELAY_URL" /opt/chatmail && \
    cd /opt/chatmail && \
    git checkout "$RELAY_REF"

WORKDIR /opt/chatmail

# cmdeploy venv (editable so importlib.resources reads from the source tree).
RUN python3 -m venv /opt/cmdeploy && \
    /opt/cmdeploy/bin/pip install --upgrade pip && \
    /opt/cmdeploy/bin/pip install -e chatmaild/ -e cmdeploy/

# Build-time: run ONLY the install stage against a dummy domain. No systemd
# required — the install stage is container-aware.
RUN printf '[params]\nmail_domain = build.local\n' > /tmp/chatmail.ini && \
    CMDEPLOY_STAGES=install \
    CHATMAIL_INI=/tmp/chatmail.ini \
    /opt/cmdeploy/bin/pyinfra @local \
        /opt/chatmail/cmdeploy/src/cmdeploy/run.py -y && \
    rm -f /tmp/chatmail.ini

# Trim build-only packages (keep git: GithashDeployer runs `git rev-parse HEAD`).
RUN apt-get purge -y gcc python3-dev && apt-get autoremove -y

# Record a build version for the deploy fingerprint.
RUN echo "$RELAY_REF" > /etc/chatmail-image-version && \
    echo "$RELAY_REF" > /etc/chatmail-version

ENV PATH="/opt/cmdeploy/bin:${PATH}"
RUN mkdir -p /etc/chatmail && ln -sf /etc/chatmail/chatmail.ini /opt/chatmail/chatmail.ini

# First-boot init unit.
COPY scripts/chatmail-init.service /lib/systemd/system/chatmail-init.service
RUN ln -sf /lib/systemd/system/chatmail-init.service \
    /etc/systemd/system/multi-user.target.wants/chatmail-init.service && \
    rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true

COPY --chmod=555 scripts/chatmail-init.sh /chatmail-init.sh
COPY --chmod=555 scripts/entrypoint.sh /entrypoint.sh
COPY --chmod=555 scripts/healthcheck.sh /healthcheck.sh

HEALTHCHECK --interval=5s --start-period=240s --timeout=10s --retries=3 \
  CMD /healthcheck.sh

STOPSIGNAL SIGRTMIN+3

ENTRYPOINT ["/entrypoint.sh"]
CMD [   "--default-standard-output=journal+console", \
        "--default-standard-error=journal+console" ]
